art = design("a photonic quantum key distribution system")
print(art.report())
print(art.is_valid_ob3ect)
.fi
.RE
.PP
Async design with explicit provider:
.RS
.nf
import asyncio
from ob3ect import auto_design

art = asyncio.run(auto_design(
    "a hospital triage protocol",
    domain_type="social",
    scope="mesoscale",
    max_retries=5,
))
print(art.structural_type)
.fi
.RE
.PP
Manual pipeline (full phase control):
.RS
.nf
from ob3ect import Ob3ectPipeline

p = Ob3ectPipeline("My Ob3ect", domain_type="computational")
p.define_boundary("My System", "local",
                  ["source", "ast", "canonical"],
                  "semantic equivalence class")
p.map_opcode("VINIT",  "empty module",      "void state", [])
p.map_opcode("TANCH",  "type-checked",      "terminal",   [])
p.map_opcode("AFWD",   "ast.parse",         "delta",      [])
p.map_opcode("AREV",   "ast.unparse",       "mu",         [])
p.map_opcode("CLINK",  "compose",           "f o g",      [])
p.map_opcode("IMSCRIB", "open(__file__)",    "id",         [])
p.map_opcode("FSPLIT", "ast.parse(src)",    "A -> A@A",   [])
p.map_opcode("FFUSE",  "ast.unparse(tree)", "A@A -> A",   [])
p.map_opcode("EVALT",  "parse ok",          "True branch",[])
p.map_opcode("EVALF",  "SyntaxError",       "False branch",[])
p.map_opcode("ENGAGR", "ambiguous",         "Both",       [])
p.map_opcode("IFIX",   "write .pyc",        "ROM",        [])
p.complete_phase_1()
p.verify_frobenius("FSPLIT ast.parse(src)", "src", ["tree"],
                   "FFUSE ast.unparse(tree)", "src'",
                   "PASS", "src' equiv src under ast.compare()")
p.map_registers("not parsed", "roundtrip ok", "mismatch", "dialetheia")
p.design_bootstrap()
p.specify_exos("Python AST", "calls", "__dict__", "sequential", "importlib")
p.audit_entropy("O(n)", "raw src", "canonical src", "DeltaS = 0")
art = p.instantiate()
.fi
.RE
