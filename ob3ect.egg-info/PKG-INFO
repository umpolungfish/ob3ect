## Manual Pipeline

For complete control over each phase:

```python
from ob3ect import Ob3ectPipeline, Opcode

p = Ob3ectPipeline("My Ob3ect", domain_type="computational")

# Phase 0 тАФ Boundary
p.define_boundary("My System", "local",
                  tokens=["source", "ast", "canonical"],
                  boundary="semantic equivalence class")

# Phase 1 тАФ Opcode map (all 12 required)
p.map_opcode("VINIT",  "empty module",       "initial void state тИЕ", [])
p.map_opcode("TANCH",  "type-checked term",  "terminal anchor тКд", [])
p.map_opcode("AFWD",   "parse",              "source тЖТ AST", [])
p.map_opcode("AREV",   "unparse",            "AST тЖТ source (descent)", [])
p.map_opcode("CLINK",  "compose",            "f тИШ g on transformations", [])
p.map_opcode("IMSCRIB", "read __file__",      "self-reference тАФ id", [])
p.map_opcode("FSPLIT", "ast.parse(src)",     "comultiplication ╬┤: A тЖТ AтКЧA", [])
p.map_opcode("FFUSE",  "ast.unparse(tree)",  "multiplication ╬╝: AтКЧA тЖТ A", [])
p.map_opcode("EVALT",  "parse success",      "true lattice branch", [])
p.map_opcode("EVALF",  "SyntaxError",        "false lattice branch", [])
p.map_opcode("ENGAGR", "ambiguous AST",      "dialetheia тАФ both branches live", [])
p.map_opcode("IFIX",   "write bytecode",     "ROM fixation тАФ irreversible", [])
p.complete_phase_1()

# Phase 2 тАФ Frobenius verification (the discriminating gate)
p.verify_frobenius(
    split_opcode="FSPLIT ast.parse(src)",
    split_input="src",
    split_outputs=["tree"],
    fuse_opcode="FFUSE ast.unparse(tree)",
    fuse_output="src'",
    status="PASS",
    test_instance="src' тЙб_~ src under ast.compare()"
)

# Phase 3 тАФ Register map
p.map_registers(
    void_desc="module not yet parsed",
    true_desc="parse succeeded, unparse matches",
    false_desc="SyntaxError or structural mismatch",
    both_desc="ambiguous encoding (dialetheia held)"
)

# Phases 4тАУ7
p.design_bootstrap()
p.specify_exos("Python AST", "function calls", "module __dict__",
               "sequential", "importlib")
p.audit_entropy("O(n) AST walk", "raw source string",
                "canonical unparse", "╬ФS тЙИ 0")

artifact = p.instantiate()
print(artifact.report())
```

